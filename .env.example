# SQLite database location (Prisma resolves file: URLs relative to backend/prisma/)
DATABASE_URL="file:../data/automail.db"

# Public application URL used for OAuth callbacks. Docker Compose routes /api
# through the frontend, so the local value has no backend port.
BACKEND_URL=http://localhost

# Frontend URL (for OAuth redirects) - update for production
FRONTEND_URL=http://localhost

# Microsoft OAuth - get from Azure Portal
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret

# Set to true to disable Microsoft OAuth entirely (hides the option in the UI
# and blocks all OAuth endpoints, including token refresh for existing accounts)
DISABLE_MICROSOFT_OAUTH=false

# JWT Secret for OAuth state tokens (generate with: openssl rand -hex 32).
# Leaving secrets empty uses the development-only Docker Compose defaults.
JWT_SECRET=

# Encryption key for storing tokens (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# better-auth (generate secret with: openssl rand -hex 32)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost

# Optional SAML SSO. Leave SAML_ENABLED=false to keep local email/password as
# the only sign-in method.
SAML_ENABLED=false
SAML_PROVIDER_ID=default-saml
SAML_DOMAIN=
SAML_ENTRY_POINT=
# The IdP's own entityID/issuer (found in its metadata XML) — required so the
# SP can validate the <Issuer> on incoming responses.
SAML_IDP_ENTITY_ID=
# Base64-encoded IdP signing certificate PEM (no line breaks), e.g.
# `base64 -i idp-cert.pem | tr -d '\n'`
SAML_CERT=
SAML_IDENTIFIER_FORMAT=urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress
