# SQLite database location (Prisma resolves file: URLs relative to backend/prisma/)
DATABASE_URL="file:../data/automail.db"

# Backend URL (used for OAuth callbacks) - update for production
BACKEND_URL=http://localhost:4000

# Frontend URL (for OAuth redirects) - update for production
FRONTEND_URL=http://localhost

# Microsoft OAuth - get from Azure Portal
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret

# Set to true to disable Microsoft OAuth entirely (hides the option in the UI
# and blocks all OAuth endpoints, including token refresh for existing accounts)
DISABLE_MICROSOFT_OAUTH=false

# JWT Secret for OAuth state tokens (generate with: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-here

# Encryption key for storing tokens (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-encryption-key-here

# better-auth (generate secret with: openssl rand -hex 32)
BETTER_AUTH_SECRET=your-better-auth-secret-here
BETTER_AUTH_URL=http://localhost:4000
