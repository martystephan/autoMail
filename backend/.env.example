PORT=4000
DATABASE_URL="file:../data/automail.db"

# Backend URL (used for OAuth callbacks)
BACKEND_URL=http://localhost:4000

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Set to true to disable Microsoft OAuth entirely (hides the option in the UI
# and blocks all OAuth endpoints, including token refresh for existing accounts)
DISABLE_MICROSOFT_OAUTH=false

# JWT Secret for OAuth state tokens (unrelated to user auth/sessions below)
JWT_SECRET=

# Encryption key for storing tokens (32 bytes hex = 64 chars)
ENCRYPTION_KEY=

# better-auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4000

# SAML SSO (better-auth @better-auth/sso plugin). Leave SAML_ENABLED=false to
# keep local email/password as the only sign-in method.
SAML_ENABLED=false
SAML_PROVIDER_ID=default-saml
SAML_DOMAIN=
SAML_ENTRY_POINT=
# The IdP's own entityID/issuer (found in its metadata XML) — required so the
# SP can validate the <Issuer> on incoming responses.
SAML_IDP_ENTITY_ID=
# Base64-encoded IdP signing certificate PEM (no line breaks), e.g.
# `base64 -i idp-cert.pem | tr -d '\n'`
SAML_CERT=
SAML_IDENTIFIER_FORMAT=urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress
